# ShopBuilder Backend — required environment variables for the prod profile
# Copy this file to .env and fill in real values. Never commit .env to version control.

# PostgreSQL connection URL
# Format: jdbc:postgresql://<host>:<port>/<dbname>
DB_URL=jdbc:postgresql://localhost:5432/shopbuilder

# PostgreSQL credentials
DB_USERNAME=shopbuilder_user
DB_PASSWORD=change_me

# JWT signing secret (minimum 32 characters recommended)
JWT_SECRET=replace-with-a-long-random-secret-key

# Frontend origin allowed by CORS (no trailing slash)
APP_CORS_ALLOWED_ORIGIN=http://localhost:5173

# Storage provider: "local" (dev) or "cloudinary" (prod)
STORAGE_PROVIDER=cloudinary

# Cloudinary account credentials URL (required when STORAGE_PROVIDER=cloudinary)
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
